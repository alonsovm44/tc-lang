use "stdlib/io.tc"

fn void main: {
    // Queue tests
    queue<i32> q = { 10, 20 }
    q.enq(30)
    printi(q.peek())
    i32 a = q.deq()
    i32 b = q.deq()
    printi(a)
    printi(b)

    // Stack tests
    stack<i32> s = { 1, 2 }
    s.push(3)
    printi(s.peek())
    i32 c = s.pop()
    i32 d = s.pop()
    printi(c)
    printi(d)
}

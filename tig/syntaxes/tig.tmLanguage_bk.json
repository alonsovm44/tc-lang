{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Tig",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#function-declaration"
		},
		{
			"include": "#types"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#inline-c"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#match-wildcard"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.tig",
					"match": "//.*$"
				},
				{
					"name": "comment.block.tig",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.tig",
					"match": "\\b(if|else|loop|break|defer|try|catch|ret|match)\\b"
				},
				{
					"name": "keyword.declaration.tig",
					"match": "\\b(fn|async|select|strun|enum|use|pub|pin|extern)\\b"
				},
				{
					"name": "constant.language.tig",
					"match": "\\b(true|false|null)\\b"
				}
			]
		},
		"function-declaration": {
			"patterns": [
				{
					"name": "meta.function.tig",
					"match": "(fn)\\s+(\\w+)\\s*:",
					"captures": {
						"1": { "name": "keyword.declaration.fn.tig" },
						"2": { "name": "entity.name.function.tig" }
					}
				}
			]
		},
		"match-wildcard": {
			"patterns": [
				{
					"name": "constant.other.symbol.tig",
					"match": "(?<=match\\s*\\([^)]*\\)\\s*\\{[^}]*)\\s*_\\s*="
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.tig",
					"match": "\\b(void|bool|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|stack|queue)\\b"
				},
				{
					"name": "storage.type.pointer.tig",
					"match": "(->|=>)\\s*\\w+"
				}
			]
		},
		"strings": {
			"name": "string.quoted.double.tig",
			"begin": "\"",
			"end": "\"",
			"patterns": [
				{
					"name": "constant.character.escape.tig",
					"match": "\\\\."
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.integer.tig",
					"match": "\\b[0-9]+\\b"
				},
				{
					"name": "constant.numeric.float.tig",
					"match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
				}
			]
		},
		"inline-c": {
			"name": "meta.embedded.c.tig",
			"begin": "\"C\"\\s*\\{",
			"end": "\\}",
			"patterns": [
				{
					"include": "source.c"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.address.tig",
					"match": "&"
				},
				{
					"name": "keyword.operator.dereference.tig",
					"match": "->"
				},
				{
					"name": "keyword.operator.fat-pointer.tig",
					"match": "=>"
				},
				{
					"name": "keyword.operator.function-ref.tig",
					"match": "@"
				},
				{
					"name": "keyword.operator.pointer-field.tig",
					"match": "\\.>"
				},
				{
					"name": "keyword.operator.assignment.tig",
					"match": "="
				},
				{
					"name": "keyword.operator.match.tig",
					"match": "(?<=match\\s*\\([^)]*\\)\\s*)\\="
				}
			]
		}
	},
	"scopeName": "source.tc"
}
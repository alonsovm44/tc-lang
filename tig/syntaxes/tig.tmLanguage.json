{
	"$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
	"name": "Tig",
	"patterns": [
		{
			"include": "#comments"
		},
		{
			"include": "#macros"
		},
		{
			"include": "#keywords"
		},
		{
			"include": "#function-definition"
		},
		{
			"include": "#function-calls"
		},
		{
			"include": "#types"
		},
		{
			"include": "#struct-enum-definitions"
		},
		{
			"include": "#strings"
		},
		{
			"include": "#numbers"
		},
		{
			"include": "#inline-c"
		},
		{
			"include": "#operators"
		},
		{
			"include": "#queue-stack"
		},
		{
			"include": "#defer-block"
		},
		{
			"include": "#pin-statement"
		},
		{
			"include": "#async-keywords"
		},
		{
			"include": "#use-statement"
		},
		{
			"include": "#enum-members"
		},
		{
			"include": "#struct-fields"
		},
		{
			"include": "#match-wildcard"
		}
	],
	"repository": {
		"comments": {
			"patterns": [
				{
					"name": "comment.line.double-slash.tig",
					"match": "//.*$"
				},
				{
					"name": "comment.block.tig",
					"begin": "/\\*",
					"end": "\\*/"
				}
			]
		},
		"macros": {
			"patterns": [
				{
					"name": "meta.macro.definition.tig",
					"begin": "^\\s*(#)(\\s*)([a-zA-Z_][a-zA-Z0-9_]*)",
					"beginCaptures": {
						"1": { "name": "keyword.control.macro.tig" },
						"3": { "name": "entity.name.function.macro.tig" }
					},
					"end": "(?<=})",
					"patterns": [
						{
							"name": "meta.macro.params.tig",
							"begin": "\\(",
							"end": "\\)",
							"beginCaptures": {
								"0": { "name": "punctuation.definition.parameters.begin.tig" }
							},
							"endCaptures": {
								"0": { "name": "punctuation.definition.parameters.end.tig" }
							},
							"patterns": [
								{
									"name": "variable.parameter.macro.tig",
									"match": "[a-zA-Z_][a-zA-Z0-9_]*"
								},
								{
									"name": "punctuation.separator.parameters.tig",
									"match": ","
								}
							]
						},
						{
							"name": "meta.macro.body.tig",
							"begin": "\\{",
							"end": "\\}",
							"beginCaptures": {
								"0": { "name": "punctuation.section.block.begin.tig" }
							},
							"endCaptures": {
								"0": { "name": "punctuation.section.block.end.tig" }
							},
							"patterns": [
								{
									"include": "#comments"
								}
							]
						}
					]
				},
				{
					"name": "meta.macro.invocation.tig",
					"match": "(#)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "keyword.control.macro.tig" },
						"2": { "name": "entity.name.function.macro.invocation.tig" }
					}
				}
			]
		},
		"keywords": {
			"patterns": [
				{
					"name": "keyword.control.tig",
					"match": "\\b(if|else|loop|break|defer|ret|match|select|continue|return)\\b"
				},
				{
					"name": "keyword.declaration.tig",
					"match": "\\b(fn|async|strun|struct|enum|use|pub|pin|extern|defer)\\b"
				},
				{
					"name": "constant.language.tig",
					"match": "\\b(true|false|null|nil|undefined)\\b"
				}
			]
		},
		"function-definition": {
			"patterns": [
				{
					"name": "meta.function.definition.tig",
					"begin": "\\b(async\\s+)?(fn)\\s+([a-zA-Z_][a-zA-Z0-9_*]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
					"beginCaptures": {
						"1": { "name": "keyword.control.async.tig" },
						"2": { "name": "keyword.declaration.fn.tig" },
						"3": { "name": "storage.type.return.tig" },
						"4": { "name": "entity.name.function.definition.tig" },
						"5": { "name": "punctuation.definition.function.parameters.tig" }
					},
					"end": "(?<=\\})",
					"patterns": [
						{
							"name": "meta.function.parameters.tig",
							"begin": "(?<=:)\\s*",
							"end": "(?=\\{)",
							"patterns": [
								{
									"name": "meta.function.parameter.tig",
									"match": "([a-zA-Z_][a-zA-Z0-9_>*]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
									"captures": {
										"1": { "name": "storage.type.parameter.tig" },
										"2": { "name": "variable.parameter.function.tig" }
									}
								},
								{
									"name": "punctuation.separator.parameters.tig",
									"match": ","
								},
								{
									"name": "keyword.operator.varargs.tig",
									"match": "\\.\\.\\."
								}
							]
						},
						{
							"name": "meta.function.body.tig",
							"begin": "\\{",
							"end": "\\}",
							"beginCaptures": {
								"0": { "name": "punctuation.section.block.begin.tig" }
							},
							"endCaptures": {
								"0": { "name": "punctuation.section.block.end.tig" }
							},
							"patterns": [
								{
									"include": "$base"
								}
							]
						}
					]
				},
				{
					"name": "meta.function.definition.old-syntax.tig",
					"begin": "\\b(async\\s+)?([a-zA-Z_][a-zA-Z0-9_]*)\\s+(fn)\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(:)",
					"beginCaptures": {
						"1": { "name": "keyword.control.async.tig" },
						"2": { "name": "storage.type.return.tig" },
						"3": { "name": "keyword.declaration.fn.tig" },
						"4": { "name": "entity.name.function.definition.tig" },
						"5": { "name": "punctuation.definition.function.parameters.tig" }
					},
					"end": "(?<=\\})",
					"patterns": [
						{
							"include": "#function-definition"
						}
					]
				}
			]
		},
		"function-calls": {
			"patterns": [
				{
					"name": "meta.function-call.tig",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "entity.name.function.call.tig" }
					}
				},
				{
					"name": "meta.method-call.tig",
					"match": "(\\.)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "punctuation.accessor.tig" },
						"2": { "name": "entity.name.function.method.tig" }
					}
				},
				{
					"name": "meta.pointer-method-call.tig",
					"match": "(\\.>)([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()",
					"captures": {
						"1": { "name": "keyword.operator.pointer-field.tig" },
						"2": { "name": "entity.name.function.method.tig" }
					}
				}
			]
		},
		"match-wildcard": {
			"patterns": [
				{
					"name": "constant.other.symbol.tig",
					"match": "\\b_\\b(?=\\s*=)",
					"captures": {
						"0": { "name": "constant.language.wildcard.tig" }
					}
				}
			]
		},
		"types": {
			"patterns": [
				{
					"name": "storage.type.tig",
					"match": "\\b(void|bool|i8|i16|i32|i64|u8|u16|u32|u64|f32|f64|char|byte|size_t|ssize_t|stack|queue)\\b"
				},
				{
					"name": "storage.type.pointer.tig",
					"match": "(->|=>)\\s*[a-zA-Z_][a-zA-Z0-9_]*"
				},
				{
					"name": "storage.type.array.tig",
					"match": "[a-zA-Z_][a-zA-Z0-9_]*\\s*\\[[^\\]]*\\]"
				}
			]
		},
		"struct-enum-definitions": {
			"patterns": [
				{
					"name": "meta.struct.definition.tig",
					"begin": "\\b(struct|strun)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"beginCaptures": {
						"1": { "name": "keyword.declaration.struct.tig" },
						"2": { "name": "entity.name.type.struct.tig" }
					},
					"end": "\\}",
					"patterns": [
						{
							"name": "meta.struct.body.tig",
							"begin": "\\{",
							"end": "\\}",
							"beginCaptures": {
								"0": { "name": "punctuation.section.block.begin.tig" }
							},
							"endCaptures": {
								"0": { "name": "punctuation.section.block.end.tig" }
							},
							"patterns": [
								{
									"include": "#struct-fields"
								}
							]
						}
					]
				},
				{
					"name": "meta.enum.definition.tig",
					"begin": "\\benum\\s+([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\{)",
					"beginCaptures": {
						"1": { "name": "keyword.declaration.enum.tig" },
						"2": { "name": "entity.name.type.enum.tig" }
					},
					"end": "\\}",
					"patterns": [
						{
							"include": "#enum-members"
						}
					]
				}
			]
		},
		"struct-fields": {
			"patterns": [
				{
					"name": "meta.struct.field.tig",
					"match": "^\\s*([a-zA-Z_][a-zA-Z0-9_>*]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)(?=\\s*[;,}])",
					"captures": {
						"1": { "name": "storage.type.field.tig" },
						"2": { "name": "variable.other.member.tig" }
					}
				},
				{
					"name": "meta.struct.union-field.tig",
					"match": "^\\s*&\\s*([a-zA-Z_][a-zA-Z0-9_>*]*)\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "storage.type.field.union.tig" },
						"2": { "name": "variable.other.member.union.tig" }
					}
				},
				{
					"name": "meta.struct.padding.tig",
					"match": "\\b_padding[0-9]+\\b",
					"captures": {
						"0": { "name": "variable.other.padding.tig" }
					}
				}
			]
		},
		"enum-members": {
			"patterns": [
				{
					"name": "meta.enum.member.tig",
					"match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\b\\s*(?=[,}])",
					"captures": {
						"1": { "name": "constant.other.enum-member.tig" }
					}
				}
			]
		},
		"strings": {
			"patterns": [
				{
					"name": "string.quoted.double.tig",
					"begin": "\"",
					"end": "\"",
					"patterns": [
						{
							"name": "constant.character.escape.tig",
							"match": "\\\\[nrt\"\\\\]"
						},
						{
							"name": "constant.character.escape.hex.tig",
							"match": "\\\\x[0-9A-Fa-f]{2}"
						}
					]
				},
				{
					"name": "string.quoted.single.tig",
					"begin": "'",
					"end": "'",
					"patterns": [
						{
							"name": "constant.character.escape.tig",
							"match": "\\\\[nrt'\\\\]"
						}
					]
				}
			]
		},
		"numbers": {
			"patterns": [
				{
					"name": "constant.numeric.integer.decimal.tig",
					"match": "\\b[0-9]+\\b"
				},
				{
					"name": "constant.numeric.integer.hex.tig",
					"match": "\\b0x[0-9A-Fa-f]+\\b"
				},
				{
					"name": "constant.numeric.integer.binary.tig",
					"match": "\\b0b[01]+\\b"
				},
				{
					"name": "constant.numeric.float.tig",
					"match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
				}
			]
		},
		"inline-c": {
			"name": "meta.embedded.c.tig",
			"begin": "\"C\"\\s*\\{",
			"end": "\\}",
			"beginCaptures": {
				"0": { "name": "keyword.declaration.inline-c.tig" }
			},
			"patterns": [
				{
					"include": "source.c"
				}
			]
		},
		"operators": {
			"patterns": [
				{
					"name": "keyword.operator.address.tig",
					"match": "&(?!&)"
				},
				{
					"name": "keyword.operator.dereference.tig",
					"match": "->(?![>=])"
				},
				{
					"name": "keyword.operator.fat-pointer.tig",
					"match": "=>"
				},
				{
					"name": "keyword.operator.ownership-transfer.tig",
					"match": "@(?![a-zA-Z_])"
				},
				{
					"name": "keyword.operator.pointer-field.tig",
					"match": "\\.>"
				},
				{
					"name": "keyword.operator.assignment.tig",
					"match": "="
				},
				{
					"name": "keyword.operator.compound-assignment.tig",
					"match": "\\+=|-=|\\*=|/=|%=|&=|\\|=|\\^=|<<=|>>="
				},
				{
					"name": "keyword.operator.match.tig",
					"match": "(?<=match\\s*\\([^)]*\\)\\s*)\\="
				},
				{
					"name": "keyword.operator.arithmetic.tig",
					"match": "[+\\-*/%]"
				},
				{
					"name": "keyword.operator.comparison.tig",
					"match": "==|<>|!=|<|>|<=|>="
				},
				{
					"name": "keyword.operator.logical.tig",
					"match": "&&|\\|\\|"
				},
				{
					"name": "keyword.operator.bitwise.tig",
					"match": "&|\\||\\^|~|<<|>>"
				},
				{
					"name": "keyword.operator.increment-decrement.tig",
					"match": "\\+\\+|--"
				}
			]
		},
		"queue-stack": {
			"patterns": [
				{
					"name": "meta.queue.creation.tig",
					"match": "queue\\s*<([^>]+)>\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*\\{([^}]*)\\}",
					"captures": {
						"1": { "name": "storage.type.queue.tig" },
						"2": { "name": "variable.other.queue.tig" }
					}
				},
				{
					"name": "meta.stack.creation.tig",
					"match": "stack\\s*<([^>]+)>\\s*([a-zA-Z_][a-zA-Z0-9_]*)\\s*=\\s*\\{\\}",
					"captures": {
						"1": { "name": "storage.type.stack.tig" },
						"2": { "name": "variable.other.stack.tig" }
					}
				},
				{
					"name": "support.method.queue-stack.tig",
					"match": "\\b(push|pop|peek|enq|deq|size|clear|isEmpty|len)\\b\\s*(?=\\()"
				}
			]
		},
		"defer-block": {
			"patterns": [
				{
					"name": "meta.defer.tig",
					"begin": "\\bdefer\\s*(?=\\{)",
					"beginCaptures": {
						"0": { "name": "keyword.control.defer.tig" }
					},
					"end": "\\}",
					"patterns": [
						{
							"include": "$base"
						}
					]
				},
				{
					"name": "meta.defer.statement.tig",
					"match": "\\bdefer\\s+([a-zA-Z_][a-zA-Z0-9_]*\\s*\\([^)]*\\))\\s*(?![{])",
					"captures": {
						"1": { "name": "meta.function-call.tig" }
					}
				}
			]
		},
		"pin-statement": {
			"patterns": [
				{
					"name": "meta.pin.tig",
					"match": "\\bpin\\s+([a-zA-Z_][a-zA-Z0-9_]*)",
					"captures": {
						"1": { "name": "variable.other.pinned.tig" }
					}
				}
			]
		},
		"async-keywords": {
			"patterns": [
				{
					"name": "keyword.control.async.tig",
					"match": "\\basync\\b\\s*(?=fn)"
				},
				{
					"name": "keyword.control.await.tig",
					"match": "\\bawait\\b"
				}
			]
		},
		"use-statement": {
			"patterns": [
				{
					"name": "meta.use.tig",
					"begin": "(use|@use)\\s+",
					"beginCaptures": {
						"1": { "name": "keyword.directive.use.tig" }
					},
					"end": "$",
					"patterns": [
						{
							"name": "string.quoted.double.tig",
							"match": "\"[^\"]*\""
						}
					]
				}
			]
		}
	},
	"scopeName": "source.tc"
}
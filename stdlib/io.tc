// stdio.h already included in codegen

fn void print: ->i8 s {  
    printf("%s", s)
}
fn void printi: i64 n { 
    printf("%ld", n)
}
fn void printn: ->i8 s { 
    printf("%s", s)
    putchar(10)
}
fn i32 readc: { ret getchar() }
fn i32 putchr: i32 c { ret putchar(c) } 
// no file functions
fn i32 scan: ->i8 fmt, ... {
    ret scanf(fmt, ...)
}

fn i32 fprints: ->i8 str, ->i8 fmt, ... {
    ret sprintf(str, fmt, ...)
}
extern "C" {
    i32 fn rand: 
    i32 fn srand: u32 seed 
    i32 fn rand_range: i32 min, i32 max 
    i32 fn rand_bool: 
}

// initialize random seed
void fn srand: u32 seed {
    srand(seed)
    ret
}

// get random integer (0 to RAND_MAX)
i32 fn rand: {
    ret rand()
}

// get random integer in range [min, max]
i32 fn rand_range: i32 min, i32 max {
    ret rand_range(min, max)
}

// get random boolean (0 or 1)
i32 fn rand_bool: {
    ret rand_bool()
}

use "stdlib/io.tc"

fn i32 main: {
    printn("Opening file...")
    ->FILE f = open_file("fresh_test.txt", "r")
    
    if(!f){
        print("Error: could not open file")
        ret 1
    }
    
    printn("File opened, reading first char...")
    i32 c = fgetc(f)
    printn("First char: ")
    printi(c)
    
    fclose(f)
    printn("Done")
    ret 0
}

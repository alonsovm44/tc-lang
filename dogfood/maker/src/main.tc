use "stdlib/io.tc"
use "stdlib/fs.tc"


error NoMakerfile:  {
    print("No Makerfile was found in this directory.")
}

fn i8 checkMF: {
    /// check if Makerfile exists in CWD
    if(fileExists("Makerfile")==1){
        ret 1
    }
    throw NoMakerfile()
}

fn i32 main: =>->i8 args{ 
    
    try{
        checkMF()
    }catch{
        NoMakerfile() ret 1
        _ {
            print("Unknown Error")
            ret -99
        }
    }


    ret 0
}
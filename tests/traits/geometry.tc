// ===== std/collections/geometry.tc =====
% geometry {
    strun Point {
        i32 x,
        i32 y
        
        fn void print: {
            print("(" + x + ", " + y + ")")
        }
        
        fn void move: i32 dx, i32 dy {
            x = x + dx
            y = y + dy
        }
        
        fn i32 distance_to: Point other {
            i32 dx = x - other.x
            i32 dy = y - other.y
            ret sqrt(dx * dx + dy * dy)
        }
    }
    
    strun Circle {
        Point center,
        i32 radius
        
        fn void print: {
            print("Circle at center: ")
            center.print()
            print("Radius: " + radius)
        }
        
        fn bool contains: Point p {
            ret center.distance_to(p) <= radius
        }
    }
}


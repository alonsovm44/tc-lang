/*
List of traits:
- async
- test
- debug
- volatile
- interrupt
- nostd
- naked
*/


#[async]
fn void foo: ->i8 text
{
    /// async fn
    print(text)
}

/// for legacy reasons this is still valid
/*
async fn bazz: {} but only for async, the new traits and future custom traits require #[] syntax
I am too lazy to remove inline async for now and AI is expensive.
*/
#[naked, test]
fn i32 nakedfn: {
    return 42
}

fn void main: {
    ->i8 msg = "aaa"
    foo(@msg) // since msg is an owned type we need to transfer ownership to foo to be used
    i32 result = nakedfn()
    print(result)
}
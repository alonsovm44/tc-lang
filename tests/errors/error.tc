use "stdlib/io.tc"
use "stdlib/error.tc"

error ZeroDivision: i32 x, i32 y {
    printf("Error: division by zero: %d / %d\n", x, y)
    // this can contain clean up code, Tig error self clean
    // no return statement needed
    // can include free(buff)
}
fn f64 divide: i32 x, i32 y {
    if (y == 0){
        throw ZeroDivision(x, y)
    }
    ret (f64)x / (f64)y
}
fn i32 main: {

    printn("Testing error functions")
    i32 x = 10
    i32 y = 0

    try {
        divide(x,y)
    }
    catch {
        ZeroDivision(x, y) ret 1,
        _ {
            printf("Unknown error\n")
            ret 1
        }
    }
    ret 0

}

 
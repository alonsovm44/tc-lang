use "stdlib/async.tc"
use "stdlib/io.tc"
use "stdlib/snq.tc"

async fn void worker: i32 id, ->queue<i32> out { // have to pass a ptr to a queue
    out.enq(id * 2)
}

fn i32 main: {
    
    queue<i32> results = {}
    
    // Spawn all workers
    i32 i = 0
    loop if(i < 50) {
        worker(i, &results)
        i++
    }    
    // Wait for all to complete
    // how?
    // Now safe to pop
    i32 j = 0
    loop if(j < 50) {
        printi(results.deq())
        j++
    }
}

// using queues as channels demo
use "stdlib/io.tc"
use "stdlib/snq.tc"
use "stdlib/async.tc"

async fn void worker: i32 id, ->queue<i32> out {
    out.push(id * 2)
}

fn i32 main: {
    queue<i32> results = {}

    i32 i = 0
    loop if(i < 5) {
        worker(i, &results)
        i = i + 1
    }

    i32 j = 0
    loop if(j < 5) {
        i32 result = results.deq()
        printi(result)
        j = j + 1
    }
    ret 0
}
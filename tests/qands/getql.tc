use "stdlib/io.tc"
// deprecated, now built in method .size()
fn i32 getQLen: queue<u8> q{

    u8 i = 0
    i32 counter = 0
    loop
    {
        //i = q.pop() // but this destroys the queue
        i = q.peek()
        if (i == stoi("")) // or could be q.isBlocked() built in method, so as to know if we hit cealing/floor
        {
            counter++
        }
        else
        {
            break
        }
    }
    ret counter

}

fn i32 main: {
    queue<i32> q = {}

    i32 qlen = getQLen(q)
    printi(qlen)
}
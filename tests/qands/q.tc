use "stdlib/io.tc"
use "stdlib/snq.tc" // NEW: module now with queues and stacks

fn i32 main: {
    queue<i32> q = {}

    q.enq(1) // queues can use both enq and push
    q.enq(2)

    printi(q.pop())
    printi(q.pop()) // should print 2, not 1

    stack<i32> s = {}
    s.push(1)
    s.push(2)

    printi(s.pop())
    printi(s.pop()) // should print 1, not 2
    ret 0
}
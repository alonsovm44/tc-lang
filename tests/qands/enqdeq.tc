use "stdlib/io.tc"
use "stdlib/snq.tc" // NEW: module now with queues and stacks

{
    queue<i32> q = {}
    q.enq(1)
    q.enq(2)
    q.enq(3)
    printi(q.deq())
    printi(q.deq())
    printi(q.deq())
    // both work
    // todo: make deq and enq work on queues only, 
    // and push and pop work on stacks only
    queue<i32> q2 = {}
    q2.push(1)
    q2.push(2)
    q2.push(3)
    printi(q2.pop())
    printi(q2.pop())
    printi(q2.pop())
}
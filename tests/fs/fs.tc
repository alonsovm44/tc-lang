use "stdlib/fs.tc"
@use "stdlib/io.tc"

fn void main: 
{
    ->FILE f = openf("test.txt", "r")
    if (f == 0) {
        print("Failed to open file")
        ret
    }
    print("Successfully opened file")
    
    loop if(!eof(f))
    {
        i32 c = filegetc(f)
        putchr(c)
    }
    closef(f)
}
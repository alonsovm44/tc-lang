"C"{
    #include "raylib.h"
    Color raywhite = RAYWHITE
    Color black = BLACK
}

fn void main: {
    InitWindow(800, 600, "Test")
    SetTargetFPS(60)

    loop if(!WindowShouldClose()){
        // hang
        BeginDrawing()
        ClearBackground(raywhite)
        DrawText("Hello from Tig!", 10, 10, 20, black)
        EndDrawing()
        
    }
    CloseWindow()
}
/*
build cmd:
./tigc tests/flags/ray.tc -c rayapp -- -Isrc -IC:/raylib/raylib/src -LC:/raylib/raylib/build/raylib -lraylib -lws2_32 -lwinhttp -lopengl32 -lgdi32 -lwinmm
*/
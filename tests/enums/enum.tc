use "stdlib/io.tc"

enum Piece
{
    PAWN,
    KING,
    QUEEN
} 

fn i32 main: {
    Piece piece 

    piece = 1

    match(piece){
        PAWN = {
            print("Piece is pawn")
        }
        KING = {
            print("Piece is king")
        }
        QUEEN = {
            print("piece is queen")
        }
        _ = {
            print("Unknown piece")
        }
    }
}
// should print option 2, Correct: it prints "piece is a king"
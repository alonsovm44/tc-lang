use "stdlib/io.tc"

strun Person{
    i8 age
    ->i8 name
}

void fn bar: Person p {
    p.age = 21
    p.name = "Jane"
}

void fn foo: ->Person p {
    p.>age = 23
    p.>name = "John"
}

// can also be done like this

void fn boo: ->Person p {
    (->p).age = 23
    (->p).name = "John"
}

void fn main: {
    Person p
    bar(p)
    foo(&p)
    printi(p.age)
    print(p.name)
}
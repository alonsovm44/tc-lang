use "stdlib/io.tc"

strun TestStruct {
    i32 a
    i64 b
    f32 c
}

fn void main: {
    print("Testing sizeof functionality\n")
    
    // Test basic types
    i32 i32_size = sizeof(i32)
    i32 i64_size = sizeof(i64)
    i32 f32_size = sizeof(f32)
    i32 f64_size = sizeof(f64)
    
    print("i32 size: ")
    printi(i32_size)
    print("\n")
    
    print("i64 size: ")
    printi(i64_size)
    print("\n")
    
    print("f32 size: ")
    printi(f32_size)
    print("\n")
    
    print("f64 size: ")
    printi(f64_size)
    print("\n")
    
    // Test with struct
    i32 struct_size = sizeof(TestStruct)
    print("TestStruct size: ")
    printi(struct_size)
    print("\n")
    
    // Test pointer types
    i32 ptr_size = sizeof(->i32)
    print("Pointer size: ")
    printi(ptr_size)
    print("\n")
    
    print("sizeof test completed!\n")
}

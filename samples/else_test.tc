use "stdlib/io.tc"
// away with _if hacks and added else if finnaly for ergonomics

fn void main: {
    i32 score = 85

    if (score >= 90) {
        print("A\n")
    } else if (score >= 80) {
        print("B\n")
    } else if (score >= 70) {
        print("C\n")
    } else if (score >= 60) {
        print("D\n")
    } else {
        print("F\n")
    }
}

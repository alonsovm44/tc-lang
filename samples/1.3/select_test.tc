// Test file for select statement
use "stdio.h"

fn i32 main() {
    printf("Testing select statement\n");
    
    // Test 1: Basic select with queues
    queue i32 q1 = queue_create(5);
    queue i32 q2 = queue_create(5);
    
    // Add some values to queues
    q1.push(10);
    q2.push(20);
    
    printf("Created queues and added values\n");
    
    // Basic select statement
    select {
        q1.pop() => {
            printf("Selected from queue 1\n");
        },
        q2.pop() => {
            printf("Selected from queue 2\n");
        }
    }
    
    // Test 2: Select with single statement cases
    queue i32 q3 = queue_create(5);
    q3.push(30);
    
    select {
        q3.pop() => printf("Single statement case executed\n");
    }
    
    // Test 3: Select with different types
    queue i32 int_q = queue_create(5);
    queue f64 float_q = queue_create(5);
    
    int_q.push(42);
    float_q.push(3.14);
    
    select {
        int_q.pop() => {
            printf("Got integer from queue\n");
        },
        float_q.pop() => {
            printf("Got float from queue\n");
        }
    }
    
    // Test 4: Select with stack operations
    stack i32 s = stack_create(5);
    s.push(100);
    
    select {
        s.pop() => {
            printf("Selected from stack\n");
        }
    }
    
    printf("Select statement tests completed\n");
    ret 0;
}

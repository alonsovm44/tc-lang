// Test file for concurrency patterns with async functions
use "stdio.h"

// Worker function that processes items from a queue
async fn void worker(queue i32 work_queue, i32 worker_id) {
    loop {
        i32 work = work_queue.pop();
        printf("Worker %d processed: %d\n", worker_id, work);
    }
}

// Producer function that generates work
async fn void producer(queue i32 work_queue) {
    for (i32 i = 0; i < 10; i++) {
        work_queue.push(i);
        printf("Produced: %d\n", i);
    }
}

// Test 1: Producer-consumer pattern
fn void test_producer_consumer() {
    printf("Testing producer-consumer pattern\n");
    
    queue i32 work_queue = queue_create(20);
    
    // Start producer and workers
    producer(work_queue);
    worker(work_queue, 1);
    worker(work_queue, 2);
    
    printf("Started producer and workers\n");
}

// Test 2: Pipeline pattern
async fn void stage1(queue i32 in_q, queue i32 out_q) {
    loop {
        i32 item = in_q.pop();
        i32 result = item * 2;  // Double the value
        out_q.push(result);
        printf("Stage 1: %d -> %d\n", item, result);
    }
}

async fn void stage2(queue i32 in_q, queue i32 out_q) {
    loop {
        i32 item = in_q.pop();
        i32 result = item + 10;  // Add 10
        out_q.push(result);
        printf("Stage 2: %d -> %d\n", item, result);
    }
}

fn void test_pipeline() {
    printf("Testing pipeline pattern\n");
    
    queue i32 input = queue_create(10);
    queue i32 middle = queue_create(10);
    queue i32 output = queue_create(10);
    
    // Start pipeline stages
    stage1(input, middle);
    stage2(middle, output);
    
    // Feed input
    for (i32 i = 1; i <= 5; i++) {
        input.push(i);
    }
    
    printf("Pipeline started\n");
}

// Test 3: Fan-out pattern
async fn void fan_out_worker(queue i32 work_queue, i32 worker_id) {
    loop {
        i32 work = work_queue.pop();
        printf("Fan-out worker %d got: %d\n", worker_id, work);
    }
}

fn void test_fan_out() {
    printf("Testing fan-out pattern\n");
    
    queue i32 work_queue = queue_create(50);
    
    // Start multiple workers
    fan_out_worker(work_queue, 1);
    fan_out_worker(work_queue, 2);
    fan_out_worker(work_queue, 3);
    fan_out_worker(work_queue, 4);
    
    // Distribute work
    for (i32 i = 0; i < 20; i++) {
        work_queue.push(i);
    }
    
    printf("Fan-out pattern started\n");
}

// Test 4: Select-based multiplexing
async fn void multiplexer(queue i32 q1, queue i32 q2, queue i32 output) {
    loop {
        select {
            q1.pop() => {
                i32 item = q1.pop();
                output.push(item);
                printf("Multiplexed from q1: %d\n", item);
            },
            q2.pop() => {
                i32 item = q2.pop();
                output.push(item);
                printf("Multiplexed from q2: %d\n", item);
            }
        }
    }
}

fn void test_multiplexing() {
    printf("Testing select-based multiplexing\n");
    
    queue i32 q1 = queue_create(10);
    queue i32 q2 = queue_create(10);
    queue i32 output = queue_create(20);
    
    // Start multiplexer
    multiplexer(q1, q2, output);
    
    // Send data to both input queues
    for (i32 i = 0; i < 5; i++) {
        q1.push(i * 10);
        q2.push(i * 100);
    }
    
    printf("Multiplexing test started\n");
}

fn i32 main() {
    printf("Testing Tig 1.3 Concurrency Patterns\n");
    
    test_producer_consumer();
    test_pipeline();
    test_fan_out();
    test_multiplexing();
    
    printf("All concurrency tests started\n");
    printf("Note: These are long-running tests with infinite loops\n");
    
    ret 0;
}

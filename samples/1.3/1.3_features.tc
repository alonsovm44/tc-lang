        return 42;
    }
    
    // E011: Giving non-owned variable without @
    i32 x = 10;
    consume_pointer(x);  // ERROR: Cannot give owned variable without @
    
    // E010: Accessing dead variable
    ->i32 ptr = malloc(sizeof(i32));
    consume_pointer(@ptr);
    printf("%d\n", *ptr);  // ERROR: Cannot access dead variable
    
    // E013: Assigning to pinned variable
    i32 y = 20;
    pin y;
    y = 30;  // ERROR: Cannot assign to pinned variable
}
*/

fn i32 main() {
    printf("Testing Tig 1.3 Features\n");
    
    test_queue_stack();
    test_ownership();
    test_pin();
    test_select();
    test_async_calls();
    
    printf("All tests completed\n");
    ret 0;
}

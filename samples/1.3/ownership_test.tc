// Test file for @ operator ownership transfer
use "stdlib/io.tc"

extern "C"{
    fn void printf: ->i8 fmt, ... {} 
}

fn void consume_int(->i32 val) {
    printf("Consumed integer: %d\n", ->val);
}

fn void consume_string(->i8 str) {
    printf("Consumed string: %s\n", str);
}

fn i32 main() {
    print("Testing @ operator ownership transfer\n");
    
    // Test 1: Basic integer ownership transfer
    ->i32 int_ptr = malloc(sizeof(i32));
    *int_ptr = 42;
    consume_int(@int_ptr);
    
    // Test 2: String ownership transfer
    ->i8 str_ptr = "Hello, Tig 1.3!";
    consume_string(@str_ptr);
    
    // Test 3: Multiple transfers
    ->i32 ptr1 = malloc(sizeof(i32));
    ->i32 ptr2 = malloc(sizeof(i32));
    *ptr1 = 100;
    *ptr2 = 200;
    
    consume_int(@ptr1);
    consume_int(@ptr2);
    
    printf("Ownership transfer tests completed\n");
    ret 0;
}

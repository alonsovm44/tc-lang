use "stdlib/io.tc"

fn i32 isNextCharBlank: ->FILE f {

    i32 c = fgetc(f)
    if (c <> "EOF"){
        ungetc(c, f)
        ret c == " "
    }
    ret c
}

void fn main: {
 ->FILE file = fopen("test.txt", "r")

 if (!file){
    print("Error, could not open file")
    ret
 }
 i32 count = 0
 loop if(!eof(file)) {
    if (isNextCharBlank(file)){}
    else {
        // consume char
        fgetc(file)
        count++
    }
 }
 print("Word count: ")
 printi(count)
 print("\n")

}
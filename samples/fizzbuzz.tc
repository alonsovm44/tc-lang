
use "stdlib/io.tc" //for print and printi

fn void fizzbuzz: i32 n {
    i32 i = 0
    loop if(i < n){
        if(i % 15 == 0){
            print("fizzbuzz")
        }
        else if(i % 3 == 0){
            print("fizz")
        }
        else if(i % 5 == 0){
            print("buzz")
        }
        else {
            printi(i)
        }
        i++
    }
}

fn i32 main:{
    fizzbuzz(120)
    ret 0
}

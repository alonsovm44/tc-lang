use "stdlib/io.tc"

fn i32 add: i32 a, i32 b {
    ret a + b
}

fn i32 mul: i32 a, i32 b {
    ret a * b
}

fn i32 apply: fn(i32, i32)i32 op, i32 a, i32 b {
    ret op(a, b)
}

fn void main: {
    fn(i32, i32)i32 fp = @add
    printi(fp(3, 4))       // 7

    fp = @mul
    printi(fp(3, 4))       // 12

    printi(apply(@add, 10, 5))  // 15
    printi(apply(@mul, 10, 5))  // 50
}

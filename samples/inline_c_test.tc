use "stdlib/io.tc"

fn void main: {
    print("Testing inline C functionality\n")
    
    // Basic inline C test
    "C"{
        printf("Hello from inline C!\n");
        int x = 42;
        printf("C variable x = %d\n", x);
    }
    
    // Inline C with TightC variables
    i32 tc_var = 100
    "C"{
        // Access TightC variables (they'll be available in the generated C)
        printf("TightC variable value: %d\n", tc_var);
    }
    
    // Inline C with control flow
    i32 counter = 0
    "C"{
        for(int i = 0; i < 3; i++) {
            printf("Inline C loop iteration %d\n", i);
            counter++;  // Modify TightC variable
        }
    }
    
    print("Final counter value: ")
    printi(counter)
    
    // Inline C with function call
    "C"{
        void custom_function(void) {
            printf("Custom function defined in inline C\n");
        }
        custom_function();
    }
    
    print("Inline C test completed!\n")
}

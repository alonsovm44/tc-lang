use "stdlib/io.tc"

fn void describe: i32 n {
    match (n) {
        1 = {
            print("one")
        }
        2 = {
            print("two")
        }
        3 = {
            print("three")
        }
        _ = {
            print("other")
        }
    }
}

fn void main: {
    describe(1)
    describe(2)
    describe(3)
    describe(99)
}
